// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("POSTGRES_PRISMA_URL") // uses connection pooling
  directUrl = env("POSTGRES_URL_NON_POOLING") // uses a direct connection
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  username      String?   @unique
  password      String?
  emailVerified DateTime?
  image         String?
  role          Role      @default(USER)
  status        Status    @default(PENDING)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  savedLeads    SavedLead[]
}

enum Role {
  USER
  ADMIN
}

enum Status {
  PENDING
  APPROVED
  REJECTED
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model SavedLead {
  id                  String   @id @default(cuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  placeId             String
  name                String
  address             String?
  category            String?
  phone               String?
  website             String?
  description         String?  @db.Text
  distance            Float?

  // CRM Fields
  qualificationStatus String   @default("Consider") // 'Consider', 'Skip'
  communicationStatus String   @default("Pending")  // 'Pending', 'Email Sent', 'Phone Call Done', 'In-Person Meeting'
  leadOutcome         String   @default("In Progress") // 'In Progress', 'Yes', 'No'
  complexityScore     Int      @default(0) // 1 to 10
  pricingEstimate     String   @default("")
  notes               String?  @db.Text

  // CRM Event Timestamps
  calledAt            DateTime?
  metAt               DateTime?
  leadGeneratedAt     DateTime?
  workStartedAt       DateTime?
  projectDeliveredAt  DateTime?
  closedAt            DateTime?

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([userId, placeId])
  @@index([userId])
}
